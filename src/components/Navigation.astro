---
import type { NavigationItem } from '../constants/site';
import { NAVIGATION } from '../constants/site';

const pathname = new URL(Astro.request.url).pathname;

const isActive = (path: string) => {
  if (path === '/') return pathname === '/';
  return pathname.startsWith(path);
};
---

<nav aria-label='Main navigation'>
  <div class='nav-links' role='menubar'>
    {
      NAVIGATION.main.map(({ name, path }: NavigationItem, index: number) => (
        <a
          href={path}
          class={isActive(path) ? 'active' : ''}
          role='menuitem'
          aria-current={isActive(path) ? 'page' : undefined}
          tabindex={index === 0 ? 0 : -1}
          data-nav-item
        >
          <span class='nav-text'>
            {name === "Let's Chat" && (
              <i class='fa-solid fa-envelope-open-text' />
            )}
            {name}
          </span>
          {isActive(path) && <span class='sr-only'>(current page)</span>}
        </a>
      ))
    }
  </div>
</nav>

<script>
  function initNav() {
    const navLinks = document.querySelector('.nav-links') as HTMLElement | null;
    if (!navLinks) return;

    // Sliding glass indicator
    const indicator = document.createElement('span');
    indicator.className = 'nav-indicator';
    navLinks.prepend(indicator);

    const activeLink = navLinks.querySelector('a.active') as HTMLElement | null;

    function moveIndicator(el: HTMLElement | null, animate: boolean) {
      if (!el) { indicator.style.opacity = '0'; return; }
      indicator.style.transition = animate
        ? 'transform 0.28s cubic-bezier(0.4,0,0.2,1), width 0.28s cubic-bezier(0.4,0,0.2,1), opacity 0.2s ease'
        : 'none';
      indicator.style.opacity = '1';
      indicator.style.width = el.offsetWidth + 'px';
      indicator.style.height = el.offsetHeight + 'px';
      indicator.style.top = el.offsetTop + 'px';
      indicator.style.left = el.offsetLeft + 'px';
    }

    // Snap to active on load, then re-enable transitions
    moveIndicator(activeLink, false);
    requestAnimationFrame(() => requestAnimationFrame(() => {
      indicator.style.transition = '';
    }));

    const links = Array.from(navLinks.querySelectorAll('a')) as HTMLElement[];

    links.forEach((link) => {
      link.addEventListener('mouseenter', () => moveIndicator(link, true));
      link.addEventListener('focus', () => moveIndicator(link, true));
    });

    navLinks.addEventListener('mouseleave', () => moveIndicator(activeLink, true));
    navLinks.addEventListener('focusout', (e: FocusEvent) => {
      if (!navLinks.contains(e.relatedTarget as Node)) moveIndicator(activeLink, true);
    });

    // Keyboard navigation
    links.forEach((item, index) => {
      item.addEventListener('keydown', (event: KeyboardEvent) => {
        let nextIndex: number;
        switch (event.key) {
          case 'ArrowRight':
          case 'ArrowDown':
            event.preventDefault();
            nextIndex = index + 1 >= links.length ? 0 : index + 1;
            links[nextIndex].focus();
            break;
          case 'ArrowLeft':
          case 'ArrowUp':
            event.preventDefault();
            nextIndex = index - 1 < 0 ? links.length - 1 : index - 1;
            links[nextIndex].focus();
            break;
          case 'Home':
            event.preventDefault();
            links[0].focus();
            break;
          case 'End':
            event.preventDefault();
            links[links.length - 1].focus();
            break;
        }
      });
    });
  }

  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>

<style>
  nav {
    display: flex;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 10;
    padding: 1rem 0;
    background: transparent;
  }

  .nav-links {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0.375rem 0.5rem;
    flex-wrap: wrap;
    position: relative;

    background: rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.14),
      0 4px 24px rgba(0, 0, 0, 0.3);
  }

  .nav-links::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      155deg,
      rgba(255, 255, 255, 0.1) 0%,
      transparent 55%
    );
    pointer-events: none;
  }

  .nav-indicator {
    position: absolute;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.12);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 1px 6px rgba(0, 0, 0, 0.2);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
  }

  a {
    color: var(--text-muted);
    text-decoration: none !important;
    font-size: var(--text-sm);
    font-weight: 700;
    transition: color var(--transition-base);
    position: relative;
    padding: 0.35rem 1rem;
    border-radius: 100px;
    outline: 2px solid transparent;
    outline-offset: 4px;
    z-index: 1;
  }

  a:hover,
  a.active {
    color: var(--text-color);
  }

  a:focus-visible {
    outline-color: var(--text-color);
    outline-offset: 4px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 768px) {
    .nav-links {
      gap: 0.1rem;
      padding: 0.3rem 0.4rem;
    }

    a {
      padding: 0.4rem 0.75rem;
    }
  }

  @media (hover: none) {
    a:hover:not(.active) {
      color: var(--text-muted);
      background: transparent;
    }
  }
</style>
