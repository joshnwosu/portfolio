---
interface Props {
  title: string;
  description?: string;
  techs?: string[];
  links?: any[];
  slug?: string;
}

const { title, description, techs, links, slug } = Astro.props;
---

<article>
  <div class='title-row'>
    <p class='subtitle'>{title}</p>
  </div>
  <p class='muted-text'>{description}</p>
  {
    techs && (
      <div class='tags'>
        {techs.map((tech) => (
          <span>{tech}</span>
        ))}
      </div>
    )
  }

  {
    (links || slug) && (
      <div class='project-links'>
        {slug && (
          <span>
            <a href={`/projects/${slug}`}>Details</a>
            <i class='fa-solid fa-chevron-right' />
          </span>
        )}
        {links &&
          links.map((link) => (
            <span>
              <a href={link.url} target='_blank' rel='noopener noreferrer'>{link.name}</a>
              {link.name === 'Github' ? (
                <i class='fa-brands fa-github' />
              ) : (
                <i class='fa-solid fa-arrow-up-right-from-square' />
              )}
            </span>
          ))}
      </div>
    )
  }
</article>

<style>
  .title-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    font-size: var(--text-sm);
  }

  .company-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .company-logo {
    width: 1.5rem;
    height: 1.5rem;
    object-fit: contain;
  }

  .tags {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .tags span {
    font-size: var(--text-xs);
    opacity: 0.5;
    background-color: var(--border-color);
    padding: 3px 10px;
    border-radius: 6px;
  }

  .project-links {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .project-links span {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-xs);
    font-weight: 500;
    background-color: var(--border-color);
    opacity: 0.7;
    padding: 4px 12px;
  }

  .project-links span:hover {
    opacity: 1;
  }
</style>
